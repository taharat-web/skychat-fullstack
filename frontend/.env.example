# Both variables are OPTIONAL. Leave them unset to use same-origin requests,
# which work out of the box with the Vite dev proxy (see vite.config.js) and
# with the bundled Nginx reverse proxy in production (see nginx.conf).
#
# Only set these if the API is hosted on a genuinely different origin than
# the frontend (no shared reverse proxy in front of both).

# VITE_API_URL=https://api.skychat.example.com/api
# VITE_SOCKET_URL=https://api.skychat.example.com
