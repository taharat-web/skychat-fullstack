# Copy this file to .env and fill in real values. Never commit .env.

# ---- Core ------------------------------------------------------------------
NODE_ENV=development
PORT=5000

# Public URL of the frontend (used for CORS + links inside emails)
CLIENT_URL=http://localhost:5173

# ---- Database ---------------------------------------------------------------
# Local dev (Postgres running on your machine or via `docker compose up postgres`)
DATABASE_URL=postgresql://skychat:skychat_password@localhost:5432/skychat

# ---- Redis (presence, rate limiting, Socket.IO horizontal scaling) --------
REDIS_URL=redis://localhost:6379

# ---- JWT / sessions ---------------------------------------------------------
# Generate strong random secrets, e.g. `openssl rand -hex 64`
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
# Refresh tokens are opaque (not JWT) and stored hashed in the DB, but we keep
# the naming consistent with the access token for clarity.
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# Cookie settings for the refresh token cookie
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ---- Email (SMTP) -----------------------------------------------------------
# Leave SMTP_HOST empty in local dev to log verification/reset emails to the
# console instead of sending real mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SkyChat <no-reply@skychat.app>"

# ---- Uploads ----------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_AVATAR_SIZE_MB=5

# ---- Rate limiting -----------------------------------------------------------
AUTH_RATE_LIMIT_WINDOW_MIN=15
AUTH_RATE_LIMIT_MAX=10
MESSAGE_RATE_LIMIT_WINDOW_SEC=10
MESSAGE_RATE_LIMIT_MAX=30
